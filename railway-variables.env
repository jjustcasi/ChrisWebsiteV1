# Railway environment variables for ChrisWebsiteV1
# Copy each KEY=VALUE into Railway Service > Variables (do NOT commit secrets to git)

NODE_ENV=production
RAILWAY_ENVIRONMENT=production
# PORT is provided by Railway automatically; do not set unless you need a custom port

# Security / auth
SESSION_SECRET=replace-with-strong-random-value
MFA_CHALLENGE_SECRET=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ReplaceWithStrongPassword!
# Optional recovery/admin account created or promoted on startup.
EXTRA_ADMIN_EMAIL=
EXTRA_ADMIN_USERNAME=
EXTRA_ADMIN_PASSWORD=

# Google OAuth (if used)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ENABLE_GOOGLE_AUTH=true

# SMTP (email notifications / email MFA)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM="CHRIS <verified-sender@example.com>"
SMTP_TIMEOUT_MS=12000
EMAIL_MFA_DEV_MODE=false

# Database (MySQL) - fill these from Railway MySQL plugin
USE_MYSQL=true
REQUIRE_MYSQL=true
# Railway usually provides these automatically on the MySQL service:
# MYSQLHOST=mysql.railway.internal
# MYSQLPORT=3306
# MYSQLUSER=...
# MYSQLPASSWORD=...
# MYSQLDATABASE=...
# You can either use those directly or map them into DB_* variables below.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional tweaks
MFA_ISSUER=CHRIS

# Notes:
# - After provisioning Railway MySQL plugin, copy its Host/Port/Username/Password/Database above.
# - If you do NOT want to use MySQL, set USE_MYSQL=false (app will use local JSON fallback, not suitable for production).
# - Keep `SESSION_SECRET` and `ADMIN_PASSWORD` strong and private.
