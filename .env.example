GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
ENABLE_GOOGLE_AUTH=false

# Required in production. Use long random values.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
# Optional recovery/admin account created or promoted on startup.
EXTRA_ADMIN_EMAIL=
EXTRA_ADMIN_USERNAME=
EXTRA_ADMIN_PASSWORD=
SESSION_SECRET=replace-with-a-long-random-secret
MFA_CHALLENGE_SECRET=replace-with-a-long-random-secret
MFA_ISSUER=CHRIS

# Railway provides PORT automatically.
# PORT=3000
NODE_ENV=production

# Use a persistent MySQL database in production.
USE_MYSQL=true
REQUIRE_MYSQL=true
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=chris_website

# Optional email MFA configuration. SendGrid example:
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM="CHRIS <verified-sender@example.com>"
SMTP_TIMEOUT_MS=12000
EMAIL_MFA_DEV_MODE=false
